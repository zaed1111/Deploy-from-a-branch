<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بوصلة الطموح المهني | متوسطة الفضيلة</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, addDoc, getDocs, query, orderBy, serverTimestamp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        // Firebase Setup
        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'alfadhila-career-v6';

        window.selectedTheme = '';
        const themeGuides = {
            'التواصل الفعال': 'المطلوب: وثق مهاراتك في التعبير عن أفكارك بلباقة، أو فيديو تشرح فيه فكرة، أو صورة لمشاركة اجتماعية قمت بها.',
            'إدارة الوقت': 'المطلوب: أرفق صورة لجدولك اليومي، أو قائمة مهام (To-do list) قمت بتنفيذها، أو اشرح كيف نظمت وقتك للمذاكرة.',
            'اتخاذ القرار': 'المطلوب: شاركنا موقفاً فكرت فيه بمنطقية واخترت الأفضل، أو أرفق صورة لخارطة ذهنية ساعدتك في اتخاذ قرار دراسي.'
        };

        window.selectTheme = function(theme) {
            window.selectedTheme = theme;
            document.querySelectorAll('.theme-btn').forEach(btn => {
                btn.classList.remove('bg-blue-600', 'text-white', 'ring-4', 'ring-blue-100');
                if(btn.innerText.includes(theme)) btn.classList.add('bg-blue-600', 'text-white', 'ring-4', 'ring-blue-100');
            });
            const guide = document.getElementById('guide-box');
            guide.classList.remove('hidden');
            guide.innerHTML = `<i class="fas fa-lightbulb ml-2 text-yellow-500"></i> ${themeGuides[theme]}`;
        };

        window.toggleView = function(view) {
            if(view === 'admin') {
                const p = prompt("أدخل رمز دخول الموجه:");
                if(p !== "1234") return alert("الرمز غير صحيح");
                loadSubmissions();
            }
            document.getElementById('student-view').classList.toggle('hidden', view !== 'student');
            document.getElementById('admin-view').classList.toggle('hidden', view !== 'admin');
        };

        async function loadSubmissions() {
            const tbody = document.getElementById('data-list');
            tbody.innerHTML = '<tr><td colspan="6" class="p-10 text-center"><i class="fas fa-spinner fa-spin text-2xl"></i></td></tr>';
            try {
                await signInAnonymously(auth);
                const q = query(collection(db, 'artifacts', appId, 'public', 'data', 'submissions'), orderBy('createdAt', 'desc'));
                const snap = await getDocs(q);
                tbody.innerHTML = '';
                snap.forEach(doc => {
                    const d = doc.data();
                    tbody.innerHTML += `
                        <tr class="border-b text-sm">
                            <td class="p-4 font-bold">${d.studentName}</td>
                            <td class="p-4">${d.grade}</td>
                            <td class="p-4"><span class="px-2 py-1 bg-blue-100 rounded text-xs">${d.theme}</span></td>
                            <td class="p-4">${d.description}</td>
                            <td class="p-4">${d.fileUrl ? '<i class="fas fa-paperclip"></i>' : '-'}</td>
                            <td class="p-4 text-gray-400">${d.createdAt?.toDate().toLocaleDateString('ar-SA') || '-'}</td>
                        </tr>`;
                });
            } catch(e) { tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-red-500">خطأ في التحميل</td></tr>'; }
        }

        document.getElementById('mainForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            if(!window.selectedTheme) return alert("فضلاً اختر المهارة أولاً");
            const btn = e.target.querySelector('button');
            btn.disabled = true;
            btn.innerText = 'جاري الإرسال...';
            try {
                await signInAnonymously(auth);
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'submissions'), {
                    studentName: document.getElementById('name').value,
                    grade: document.getElementById('grade').value,
                    theme: window.selectedTheme,
                    description: document.getElementById('desc').value,
                    fileUrl: document.getElementById('file').files[0] ? "file_attached" : "",
                    createdAt: serverTimestamp()
                });
                document.getElementById('modal').classList.remove('hidden');
            } catch(err) { alert("حدث خطأ في الإرسال"); }
            finally { btn.disabled = false; btn.innerText = 'إرسال المشاركة'; }
        });
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap');
        body { font-family: 'Tajawal', sans-serif; background-color: #f1f5f9; }
        .btn-grad { background: linear-gradient(to left, #1e40af, #3b82f6); }
    </style>
</head>
<body class="min-h-screen">

    <nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 p-4 border-b border-blue-100 shadow-sm">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white shadow-lg">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <div>
                    <h1 class="font-black text-slate-800 leading-none">متوسطة الفضيلة</h1>
                    <span class="text-[10px] text-blue-600 font-bold uppercase tracking-tighter">التوجيه الطلابي</span>
                </div>
            </div>
            <button onclick="toggleView('admin')" class="text-xs bg-slate-100 text-slate-500 px-3 py-2 rounded-lg font-bold">لوحة الموجه</button>
        </div>
    </nav>

    <main id="student-view" class="max-w-3xl mx-auto px-4 py-8">
        <div class="btn-grad text-white p-10 rounded-[2.5rem] shadow-2xl mb-8 relative overflow-hidden">
            <h2 class="text-3xl font-black mb-2">بوصلة الطموح المهني</h2>
            <p class="text-blue-100">وثق خطواتك اليوم.. لتبني مستقبلك غداً</p>
            <i class="fas fa-rocket absolute -bottom-10 -left-10 text-[12rem] opacity-10"></i>
        </div>

        <form id="mainForm" class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">الاسم الثلاثي</label>
                    <input type="text" id="name" required class="w-full p-4 bg-slate-50 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 transition-all border-none shadow-inner">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">الفصل</label>
                    <select id="grade" class="w-full p-4 bg-slate-50 rounded-2xl outline-none border-none shadow-inner">
                        <option>3 - 1</option><option>3 - 2</option>
                        <option>ثاني متوسط</option><option>أول متوسط</option>
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-4">ما المهارة التي طبقتها اليوم؟</label>
                <div class="flex flex-wrap gap-3">
                    <button type="button" onclick="selectTheme('التواصل الفعال')" class="theme-btn px-6 py-3 bg-slate-50 border rounded-2xl font-bold text-sm hover:border-blue-500 transition-all">التواصل الفعال</button>
                    <button type="button" onclick="selectTheme('إدارة الوقت')" class="theme-btn px-6 py-3 bg-slate-50 border rounded-2xl font-bold text-sm hover:border-blue-500 transition-all">إدارة الوقت</button>
                    <button type="button" onclick="selectTheme('اتخاذ القرار')" class="theme-btn px-6 py-3 bg-slate-50 border rounded-2xl font-bold text-sm hover:border-blue-500 transition-all">اتخاذ القرار</button>
                </div>
                <div id="guide-box" class="hidden mt-4 p-5 bg-blue-50 text-blue-800 rounded-3xl border border-blue-100 text-sm leading-relaxed"></div>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">صف مشاركتك باختصار</label>
                <textarea id="desc" required rows="4" class="w-full p-4 bg-slate-50 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 border-none shadow-inner" placeholder="مثال: قمت بتسجيل فيديو أشرح فيه مهارة.."></textarea>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2 text-center bg-blue-50 py-4 rounded-2xl border-2 border-dashed border-blue-200 cursor-pointer hover:bg-blue-100">
                    <input type="file" id="file" class="hidden" accept="image/*,video/*">
                    <i class="fas fa-camera-retro text-2xl text-blue-500 mb-2 block"></i>
                    أرفق صورة أو فيديو للعمل
                </label>
            </div>

            <button type="submit" class="w-full btn-grad text-white py-5 rounded-[1.5rem] font-black text-xl shadow-xl hover:shadow-blue-200 active:scale-95 transition-all">
                إرسال المشاركة للموجه
            </button>
        </form>
    </main>

    <main id="admin-view" class="max-w-5xl mx-auto px-4 py-8 hidden">
        <div class="bg-white p-8 rounded-[2rem] shadow-xl">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-black">سجل الطلاب الوارد</h2>
                <button onclick="toggleView('student')" class="text-blue-600 font-bold underline">رجوع</button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-slate-50 text-slate-500 text-xs">
                        <tr><th class="p-4">الطالب</th><th class="p-4">الفصل</th><th class="p-4">المهارة</th><th class="p-4">الوصف</th><th class="p-4">مرفق</th><th class="p-4">التاريخ</th></tr>
                    </thead>
                    <tbody id="data-list"></tbody>
                </table>
            </div>
        </div>
    </main>

    <div id="modal" class="hidden fixed inset-0 bg-slate-900/80 backdrop-blur-md flex items-center justify-center p-6 z-[100]">
        <div class="bg-white p-10 rounded-[3rem] text-center max-w-sm w-full">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6 text-green-500 text-3xl animate-bounce">
                <i class="fas fa-check"></i>
            </div>
            <h3 class="text-2xl font-black mb-2">أحسنت يا بطل!</h3>
            <p class="text-slate-500 mb-8 font-medium">تم استلام مشاركتك بنجاح. استمر في التميز.</p>
            <button onclick="location.reload()" class="w-full btn-grad text-white py-4 rounded-2xl font-bold">إغلاق</button>
        </div>
    </div>

</body>
</html>
